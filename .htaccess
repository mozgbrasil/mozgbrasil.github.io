#

# https://github.com/Flootah/flootah.com/blob/d53c52873fc1ab8f36ab68903a30bcec9d248800/.htaccess

#ErrorDocument 404 404.html
#ErrorDocument 403 403.html
#Options -Indexes

# https://davidegan.me/adding-a-htaccess-file-to-a-jekyll-site/
# Set browser caching
<IfModule mod_expires.c>
ExpiresActive On
# set default
ExpiresDefault "access plus 24 hours"
ExpiresByType image/jpg "access plus 1 months"
ExpiresByType image/jpeg "access plus 1 months"
ExpiresByType image/gif "access plus 1 months"
ExpiresByType image/png "access plus 1 months"
ExpiresByType text/css "access plus 10 minutes"
ExpiresByType text/javascript "access plus 10 minutes"
ExpiresByType application/javascript "access plus 10 minutes"
ExpiresByType text/x-javascript "access 10 minutes"
ExpiresByType application/x-javascript  "access 10 minutes"
ExpiresByType text/html "access 10 minutes"
ExpiresByType application/x-shockwave-flash "access plus 1 months"
ExpiresByType application/pdf "access 1 month"
ExpiresByType image/x-icon "access 1 year"
</IfModule>
# End caching block
